htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# Pyenv
#   For a library or package, you might want to ignore these files since the Python version is individual or project-specific.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, shell activation ignores these files.
#   It's better to ignore them and let user decide if they want them.
# .env
# .venv

# Poetry
#   Check poetry documentation for their recommendations on .gitignore.
# poetry.lock

# pdm
#   Check pdm documentation for their recommendations on .gitignore.
# .pdm.toml
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# itsdangerous
#   it's common to use itsdangerous to sign cookies or other data
#   so you should ignore these secrets usually
# .secret

